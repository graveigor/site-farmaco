# Copie este arquivo para .env e preencha os valores.
#   cp .env.example .env

# Banco de dados.
# Dev local: SQLite, sem depender de servidor.
DATABASE_URL="file:./dev.db"
# Producao: troque o provider em prisma/schema.prisma para "postgresql" e use:
# DATABASE_URL="postgresql://usuario:senha@host:5432/sistemafarma?schema=public"

# Chave de assinatura das sessoes.
# Gere uma propria com:  openssl rand -base64 32
AUTH_SECRET="gere-uma-chave-com-openssl-rand-base64-32"
